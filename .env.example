# ==============================================
# CDN Pro — Variáveis de Ambiente
# Copiar para .env e preencher com os teus valores
# NUNCA colocar o .env no git
# ==============================================

# --- Base de dados PostgreSQL ---
DATABASE_URL="postgresql://user:password@localhost:5432/cdn_pro"

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=    # descomentar se Redis tiver password

# --- JWT ---
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitui_por_chave_aleatoria_forte_minimo_64_chars
JWT_EXPIRES_IN=24h

# --- Rate Limiting ---
RATE_LIMIT_TTL=60000   # janela em ms (60s)
RATE_LIMIT_MAX=100     # pedidos por janela por IP

# --- Servidor ---
NODE_ENV=development   # development | production
PORT=3000

# --- Admin inicial (usado pelo seed) ---
# Alterar antes de correr yarn db:seed em produção
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=MudarEstaPasswordImediatamente123!
