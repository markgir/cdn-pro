// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Admin users for authentication
model admin {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String    // bcrypt hashed
  name       String?
  role       String    @default("admin") // admin, editor, viewer
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  last_login DateTime?
}

// Origin servers (e-commerce stores)
model origin {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  origin_url    String   // e.g., https://shop.example.com
  type          String   @default("generic") // woocommerce, prestashop, generic
  cdn_hostname  String?  // custom CDN hostname for this origin
  cache_ttl     Int      @default(3600)
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  cache_entries cache_entry[]
  request_logs  request_log[]
}

// Cache entries metadata (actual data stored in Redis)
model cache_entry {
  id         Int      @id @default(autoincrement())
  cache_key  String   @unique
  origin_id  Int
  url        String
  content_type String?
  size_bytes Int?
  hit_count  Int      @default(0)
  created_at DateTime @default(now())
  expires_at DateTime

  origin origin @relation(fields: [origin_id], references: [id], onDelete: Cascade)
}

// HTTP request logs
model request_log {
  id           Int      @id @default(autoincrement())
  origin_id    Int?
  method       String
  url          String
  status_code  Int
  cache_status String   // HIT, MISS, MISS-STORED, NO-ORIGIN
  duration_ms  Int
  client_ip    String?
  user_agent   String?
  created_at   DateTime @default(now())

  origin origin? @relation(fields: [origin_id], references: [id], onDelete: SetNull)
}
